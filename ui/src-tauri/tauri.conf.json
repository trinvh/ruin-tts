{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beesoft Studio",
  "version": "0.1.0",
  "identifier": "com.trinvh.beesoft",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beesoft Studio",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "backgroundColor": "#15161d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/vieneu-server",
      "binaries/studio-server",
      "binaries/media-ai"
    ],
    "resources": [
      "runtime/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
